# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Hackathon API"
APP_VERSION=0.1.0
DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Paste the generated value below before running the API locally.
SECRET_KEY=replace_with_a_real_secret_key

# ── Database ──────────────────────────────────────────────────────────────────
# Async URL used by the application (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://hackathon_user:hackathon_pass@localhost:5432/hackathon_db
# Sync URL used by Alembic internals (psycopg2 driver)
DATABASE_SYNC_URL=postgresql+psycopg2://hackathon_user:hackathon_pass@localhost:5432/hackathon_db

DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/tmp/hackathon_uploads
MAX_FILE_SIZE_MB=25
ALLOWED_MIME_TYPES=["application/pdf","image/jpeg","image/png","image/tiff"]

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Keycloak ──────────────────────────────────────────────────────────────────
# URL where Keycloak is running
KEYCLOAK_URL=http://localhost:8080
# Realm name (must match keycloak/realm-export.json)
KEYCLOAK_REALM=hackathon
# Backend service client (configured in realm-export.json)
KEYCLOAK_CLIENT_ID=hackathon-api
KEYCLOAK_CLIENT_SECRET=hackathon-api-secret
# Keycloak master realm admin credentials (used only for user management API calls)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Secret required to create admin accounts via POST /auth/register/admin
ADMIN_REGISTRATION_SECRET=change-me-admin-secret

# ── Google OAuth (configure in Keycloak Admin UI after first start) ───────────
# 1. Go to http://localhost:8080/admin → hackathon realm → Identity Providers → google
# 2. Fill in your Google Cloud OAuth 2.0 Client ID and Secret
# 3. Enable the provider and set Redirect URI in Google Cloud Console to:
#    http://localhost:8080/realms/hackathon/broker/google/endpoint

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
